{
  "name": "@actio/cli",
  "version": "0.1.0",
  "description": "Actio CLI — compile .actio.yml files into GitHub Actions workflows",
  "license": "MIT",
  "type": "module",
  "bin": {
    "actio": "dist/cli.js"
  },
  "exports": {
    "./config": {
      "import": "./dist/config-export.js",
      "types": "./dist/config-export.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@actio/core": "*",
    "cac": "^7.0.0",
    "chokidar": "^5.0.0",
    "jiti": "^2.7.0",
    "picocolors": "^1.1.1",
    "tinyglobby": "^0.2.17"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
