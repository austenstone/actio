{
  "name": "actio-cli",
  "version": "0.1.0",
  "description": "Actio CLI — compile .actio.yml files into GitHub Actions workflows",
  "license": "MIT",
  "author": "Austen Stone",
  "homepage": "https://github.com/austenstone/actio#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/austenstone/actio.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/austenstone/actio/issues"
  },
  "keywords": [
    "actio",
    "github-actions",
    "ci",
    "cd",
    "yaml",
    "transpiler",
    "compiler",
    "workflow",
    "cli",
    "codegen"
  ],
  "type": "module",
  "bin": {
    "actio": "dist/cli.js"
  },
  "exports": {
    "./config": {
      "types": "./dist/config-export.d.ts",
      "import": "./dist/config-export.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "actio-core": "^0.1.0",
    "cac": "^7.0.0",
    "chokidar": "^5.0.0",
    "jiti": "^2.7.0",
    "picocolors": "^1.1.1",
    "tinyglobby": "^0.2.17"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
