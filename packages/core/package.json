{
  "name": "actio-core",
  "version": "0.1.0",
  "description": "Actio transpiler engine — compiles .actio.yml (a GitHub Actions YAML superset) into standard workflow YAML",
  "license": "MIT",
  "author": "Austen Stone",
  "homepage": "https://github.com/austenstone/actio#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/austenstone/actio.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/austenstone/actio/issues"
  },
  "keywords": [
    "actio",
    "github-actions",
    "ci",
    "cd",
    "yaml",
    "transpiler",
    "compiler",
    "workflow",
    "codegen"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "schema",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prebuild": "node scripts/build-schema.mjs",
    "build": "tsup",
    "schema:build": "node scripts/build-schema.mjs",
    "schema:refresh": "node scripts/refresh-schema.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@actions/workflow-parser": "^0.3.58",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
