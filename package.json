{
  "name": "actio-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Actio — a transpiler that compiles a .actio.yml YAML-superset into standard GitHub Actions workflows",
  "license": "MIT",
  "author": "Austen Stone",
  "homepage": "https://github.com/austenstone/actio#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/austenstone/actio.git"
  },
  "bugs": {
    "url": "https://github.com/austenstone/actio/issues"
  },
  "keywords": [
    "actio",
    "github-actions",
    "ci",
    "cd",
    "yaml",
    "transpiler",
    "compiler",
    "workflow",
    "codegen"
  ],
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*",
    ".github/actions/*"
  ],
  "scripts": {
    "build": "npm run build -w actio-core && npm run build -w actio-cli && npm run build:action",
    "build:action": "npm run build -w actio-annotate-action",
    "build:workflows": "node packages/cli/dist/cli.js build --config .github/actio/actio.config.ts",
    "check:workflows": "node packages/cli/dist/cli.js check --config .github/actio/actio.config.ts",
    "test:lint:workflows": "docker run --rm -v \"$PWD\":/repo --workdir /repo rhysd/actionlint:1.7.12 -color -shellcheck= -pyflakes= .github/workflows/*.yml",
    "docs:install": "npm --prefix docs install",
    "docs:dev": "npm --prefix docs run dev",
    "docs:build": "npm --prefix docs run build",
    "docs:api": "npm --prefix docs run api",
    "docs:preview": "npm --prefix docs run start",
    "typecheck": "npm run typecheck -w actio-core && npm run typecheck -w actio-cli && npm run typecheck -w actio-annotate-action",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^4.1.9",
    "ajv": "^8.20.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "esbuild": "^0.28.1",
    "qs": "^6.15.2"
  },
  "allowScripts": {
    "@biomejs/biome@2.5.0": true,
    "esbuild@0.28.1": true
  }
}
