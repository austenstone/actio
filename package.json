{
  "name": "actio-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Actio — a transpiler that compiles a .actio.yml YAML-superset into standard GitHub Actions workflows",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w @actio/core && npm run build -w @actio/cli",
    "build:workflows": "node packages/cli/dist/cli.js build .github/workflows/src/ci.actio.yml",
    "check:workflows": "node packages/cli/dist/cli.js check .github/workflows/src/ci.actio.yml",
    "typecheck": "npm run typecheck -w @actio/core && npm run typecheck -w @actio/cli",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/node": "^25.9.3",
    "ajv": "^8.20.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  },
  "allowScripts": {
    "@biomejs/biome@2.5.0": true,
    "esbuild@0.28.1": true
  }
}
