{
  "name": "docs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "api": "typedoc",
    "build": "typedoc && next build",
    "dev": "typedoc && next dev",
    "lint": "typedoc && fumadocs-mdx && tsx scripts/lint.ts",
    "start": "serve out",
    "types:check": "typedoc && fumadocs-mdx && next typegen && tsc --noEmit",
    "postinstall": "fumadocs-mdx"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@orama/orama": "^3.1.18",
    "actio-core": "file:../packages/core",
    "fumadocs-core": "16.10.4",
    "fumadocs-mdx": "15.0.12",
    "fumadocs-typescript": "^5.2.6",
    "fumadocs-ui": "16.10.4",
    "lucide-react": "^1.20.0",
    "monaco-editor": "^0.55.1",
    "monaco-yaml": "^5.5.1",
    "next": "16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@types/mdx": "^2.0.14",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "next-validate-link": "^1.6.6",
    "postcss": "^8.5.15",
    "serve": "^14.2.6",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.12.0",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "postcss": "^8.5.15"
  }
}
