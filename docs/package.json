{
  "name": "docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "api": "typedoc",
    "build": "typedoc && next build",
    "dev": "typedoc && next dev",
    "start": "serve out",
    "types:check": "typedoc && fumadocs-mdx && next typegen && tsc --noEmit",
    "postinstall": "fumadocs-mdx"
  },
  "dependencies": {
    "@orama/orama": "^3.1.18",
    "fumadocs-core": "16.10.4",
    "fumadocs-mdx": "15.0.12",
    "fumadocs-typescript": "^5.2.6",
    "fumadocs-ui": "16.10.4",
    "lucide-react": "^1.20.0",
    "next": "16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@types/mdx": "^2.0.14",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "postcss": "^8.5.15",
    "serve": "^14.2.6",
    "tailwindcss": "^4.3.1",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.12.0",
    "typescript": "^6.0.3"
  }
}
